    "1 año  (2024 - hoy)": (datetime.date(2024, 1, 1), datetime.date.today()),
    "2 años (2023 - hoy)": (datetime.date(2023, 1, 1), datetime.date.today()),
    "5 años (2020 - hoy)": (datetime.date(2020, 1, 1), datetime.date.today()),
